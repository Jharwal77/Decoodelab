generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Job {
  id          Int      @id @default(autoincrement())
  company     String
  position     String
  status       String   @default("Applied")
  location     String?
  appliedDate  DateTime @default(now())
  createdAt    DateTime @default(now())
}