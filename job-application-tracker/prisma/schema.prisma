generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           Int           @id @default(autoincrement())
  name         String
  email        String        @unique
  password     String
  applications Application[]
}

model Company {
  id           Int           @id @default(autoincrement())
  name         String
  location     String
  applications Application[]
}

model Application {
  id         Int      @id @default(autoincrement())
  jobTitle   String
  status     String
  userId     Int
  companyId  Int

  user        User     @relation(fields: [userId], references: [id])
  company     Company  @relation(fields: [companyId], references: [id])
}

